{
  "info": {
    "name": "Redis Caching Project",
    "description": "Spring Boot REST API for learning Redis Sorted Set operations, LRU/LFU caches, and six caching patterns with 3-tier caching (Caffeine L1 + Redis L2 + PostgreSQL DB).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Leaderboard (Sorted Set)",
      "description": "Core Redis sorted set operations exposed via a leaderboard API.",
      "item": [
        {
          "name": "1.1 ZADD - Add alice (score 2500)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"memberId\": \"alice\",\n  \"score\": 2500\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/leaderboards/gaming/members",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leaderboards", "gaming", "members"]
