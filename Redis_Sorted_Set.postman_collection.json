    {
      "name": "4. Cache-Aside",
      "description": "Cache-Aside (Lazy Loading): Write to DB first, invalidate cache. Read checks L1->L2->DB with lazy population.",
      "item": [
        {
          "name": "4.1 Clear cache",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/cache/patterns/cache-aside",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cache", "patterns", "cache-aside"]
            },
            "description": "Clear L1+L2 cache. DB data preserved."
          }
        },
        {
          "name": "4.2 Seed DB with test data",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entries\": {\n    \"laptop\": \"MacBook Pro M4\",\n    \"phone\": \"iPhone 16 Pro\",\n    \"tablet\": \"iPad Air M2\",\n    \"watch\": \"Apple Watch Ultra\",\n    \"headphones\": \"AirPods Max\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cache/patterns/cache-aside/db/seed",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cache", "patterns", "cache-aside", "db", "seed"]
            },
            "description": "Seed PostgreSQL with test data. Cache is NOT populated."
          }
        },
        {
          "name": "4.3 Read laptop (MISS - loads from DB)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/cache/patterns/cache-aside/entries/laptop",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cache", "patterns", "cache-aside", "entries", "laptop"]
            },
            "description": "Cache MISS -> loads from DB -> populates L1+L2 cache"
          }
        },
        {
          "name": "4.4 Read laptop again (HIT from L1)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/cache/patterns/cache-aside/entries/laptop",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cache", "patterns", "cache-aside", "entries", "laptop"]
            },
            "description": "Cache HIT from L1 (Caffeine) - no DB access needed"
          }
        },
        {
          "name": "4.5 Write entry (DB + invalidate cache)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"laptop\",\n  \"value\": \"MacBook Pro M4 Max\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cache/patterns/cache-aside/entries",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cache", "patterns", "cache-aside", "entries"]
            },
            "description": "Write to DB first, then invalidate L1+L2 cache"
          }
        },
        {
          "name": "4.6 Read after write (MISS - new value from DB)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/cache/patterns/cache-aside/entries/laptop",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cache", "patterns", "cache-aside", "entries", "laptop"]
            },
            "description": "Cache was invalidated by write -> MISS -> loads new value from DB"
          }
        },
        {
          "name": "4.7 View state",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/cache/patterns/cache-aside/state",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cache", "patterns", "cache-aside", "state"]
            },
            "description": "Full state: L1 entries, L2 entries, DB entries, metadata, architecture diagram"
          }
        },
        {
          "name": "4.8 View DB state",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/cache/patterns/cache-aside/db/state",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cache", "patterns", "cache-aside", "db", "state"]
            },
            "description": "View raw PostgreSQL contents for cache-aside pattern"
          }
        }
      ]
    },
    {
      "name": "5. Read-Through",
      "description": "Read-Through: Caffeine LoadingCache auto-fetches on miss with stampede protection. Write invalidates cache.",
      "item": [
        {
          "name": "5.1 Clear cache",
          "request": {
