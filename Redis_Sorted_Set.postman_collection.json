    {
      "name": "2. LRU Cache",
      "description": "Least Recently Used cache. Score = access timestamp. Evicts oldest accessed entry.",
      "item": [
        {
          "name": "2.0 Clear LRU cache (fresh start)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/cache/lru",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cache", "lru"]
            },
            "description": "Clear entire LRU cache for a clean demo"
          }
        },
        {
          "name": "2.1 Put user1 = Alice",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"user1\",\n  \"value\": \"Alice\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cache/lru/entries",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cache", "lru", "entries"]
            },
            "description": "ZADD cache:lru:access <timestamp> user1 + HSET cache:lru:data user1 Alice"
          }
        },
        {
          "name": "2.1 Put user2 = Bob",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"user2\",\n  \"value\": \"Bob\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cache/lru/entries",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cache", "lru", "entries"]
            }
          }
        },
        {
          "name": "2.1 Put user3 = Charlie",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"user3\",\n  \"value\": \"Charlie\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cache/lru/entries",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cache", "lru", "entries"]
            }
          }
        },
        {
          "name": "2.1 Put user4 = Diana",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"user4\",\n  \"value\": \"Diana\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cache/lru/entries",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cache", "lru", "entries"]
            }
          }
        },
        {
          "name": "2.1 Put user5 = Eve (cache now full 5/5)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"user5\",\n  \"value\": \"Eve\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cache/lru/entries",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cache", "lru", "entries"]
            },
            "description": "Cache is now at capacity (5/5)"
          }
        },
        {
          "name": "2.2 GET user1 (refresh timestamp, prevent eviction)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/cache/lru/entries/user1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cache", "lru", "entries", "user1"]
            },
            "description": "Access user1 to update its timestamp. Now user2 becomes the oldest."
          }
        },
        {
          "name": "2.1 Put user6 = Frank (evicts user2 - oldest access)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"user6\",\n  \"value\": \"Frank\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cache/lru/entries",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cache", "lru", "entries"]
            },
            "description": "Cache full -> evicts user2 (lowest timestamp = least recently used)"
          }
        },
        {
          "name": "2.2 GET user2 (should be MISS - was evicted)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/cache/lru/entries/user2",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cache", "lru", "entries", "user2"]
            },
            "description": "user2 was evicted - expect Cache MISS"
          }
        },
        {
          "name": "2.3 View LRU cache state",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/cache/lru/state",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cache", "lru", "state"]
            },
            "description": "Shows all entries sorted by access time. First entry = next eviction candidate."
          }
        }
      ]
    },
